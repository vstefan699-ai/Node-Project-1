<!DOCTYPE html>
<html lang="en">
<%- include('layouts/header') %>
<body>
    <%- include('layouts/navbar') %>

    <h1>Create New Post</h1>

    <% if (success_msg.length > 0) { %>
        <p style="color: green; border: 1px solid green; padding: 10px;"><%= success_msg %></p>
    <% } %>
    <% if (error_msg.length > 0) { %>
        <p style="color: red; border: 1px solid red; padding: 10px;"><%= error_msg %></p>
    <% } %>

    <form action="/posts" method="POST" enctype="multipart/form-data">
        <div>
            <label>Title</label><br>
            <input type="text" name="title" placeholder="Enter title...">
        </div>
        <br>
        <div>
            <label>Image</label><br>
            <input type="file" name="image" accept="image/*">
        </div>
        <br>
        <div>
            <label>Body</label><br>
            <!-- Quill editor will appear here -->
            <div id="editor" style="height: 200px;"></div>
            <!-- Hidden input to store the content -->
            <input type="hidden" name="body" id="body">
        </div>
        <br>
        <button type="submit" onclick="submitForm()">Publish Post</button>
    </form>

    <!-- Quill CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <!-- Quill JS -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        // Initialize Quill editor
        var quill = new Quill('#editor', {
            theme: 'snow'
        });

        // When form is submitted, copy Quill content to hidden input
        function submitForm() {
            document.getElementById('body').value = quill.root.innerHTML;
        }
    </script>

    <%- include('layouts/footer') %>
    <%- include('layouts/scripts') %>
</body>
</html>